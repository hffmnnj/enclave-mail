{
  "name": "enclave-mail",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "build": "turbo build",
    "dev": "bash scripts/dev-containers.sh && turbo dev",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:migrate": "bun run packages/db/src/migrate.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.0.0",
    "sharp": "^0.34.5",
    "turbo": "latest",
    "typescript": "^5.0.0"
  }
}
