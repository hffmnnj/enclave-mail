{
  "name": "@enclave/db",
  "version": "0.0.1",
  "private": true,
  "description": "Drizzle ORM schema, migrations, and database client",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "drizzle-orm": "latest",
    "pg": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "latest",
    "drizzle-kit": "latest"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/seed.ts"
  }
}
