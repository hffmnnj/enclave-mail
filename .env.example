# =============================================================================
# Enclave Mail — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — only .env.example is tracked.
# =============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=enclave
POSTGRES_USER=enclave
POSTGRES_PASSWORD=enclave_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://enclave:enclave_dev_password@localhost:5432/enclave

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─── Mail Server ─────────────────────────────────────────────────────────────
# The domain this server accepts mail for (production: your real domain)
SMTP_DOMAIN=localhost

# SMTP ports — ports 25 and 587 require root on Linux.
# Local dev: use 2025 / 2587 (no root needed) and update haraka/config/smtp.ini.
# Production (Docker): ports are mapped by the container, keep 25 / 587 here.
SMTP_PORT_INBOUND=2025
SMTP_PORT_SUBMISSION=2587

# IMAP port — port 993 requires root on Linux.
# Local dev: use 1993. Production (Docker): use 993.
IMAP_PORT=1993

# TLS certificate for SMTP STARTTLS and IMAPS.
# Generate a self-signed cert for dev: bash scripts/gen-certs.sh
TLS_CERT_PATH=./certs/tls.crt
TLS_KEY_PATH=./certs/tls.key

# ─── DKIM Signing ────────────────────────────────────────────────────────────
# Generate: bash scripts/gen-dkim.sh
DKIM_PRIVATE_KEY_PATH=./dkim/private.key
DKIM_SELECTOR=mail

# ─── SRP Authentication ──────────────────────────────────────────────────────
SRP_PRIME_BITS=2048

# ─── API ─────────────────────────────────────────────────────────────────────
API_PORT=3001
API_BASE_URL=http://localhost:3001
# PUBLIC_API_URL is exposed to the Astro/React frontend (PUBLIC_ prefix required).
# Must include the /api path prefix — all API routes are mounted under /api.
PUBLIC_API_URL=http://localhost:3001/api
CORS_ORIGINS=http://localhost:4321

# ─── Web / Astro Frontend ────────────────────────────────────────────────────
WEB_PORT=4321
WEB_BASE_URL=http://localhost:4321

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=86400

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Argon2id Key Derivation ─────────────────────────────────────────────────
ARGON2_MEMORY_MB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Mail Services ───────────────────────────────────────────────────────────
# Set to 'true' to start SMTP (Haraka), IMAP, and BullMQ workers.
# Leave 'false' during API/frontend development — saves ~300 MB RAM and avoids
# spawning the Haraka subprocess (the primary cause of OOM on startup).
ENABLE_MAIL_SERVICES=false

# =============================================================================
# Production only — set these when deploying
# =============================================================================
# DOMAIN=mail.example.com
# POSTGRES_PASSWORD=<strong-random-password>
# REDIS_PASSWORD=<strong-random-password>
