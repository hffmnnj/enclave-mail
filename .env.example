# =============================================================================
# Enclave Mail — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — only .env.example is tracked.
# =============================================================================

# ─── Database (dev Docker Compose) ──────────────────────────────────────────
POSTGRES_DB=enclave
POSTGRES_USER=enclave
POSTGRES_PASSWORD=enclave_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://enclave:enclave_dev_password@localhost:5432/enclave

# ─── Redis (dev Docker Compose) ──────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─── Mail Server ─────────────────────────────────────────────────────────────
# The domain this server accepts mail for
SMTP_DOMAIN=mail.yourdomain.com
# Port for inbound SMTP (MX delivery from other servers)
SMTP_PORT_INBOUND=25
# Port for authenticated mail submission (clients)
SMTP_PORT_SUBMISSION=587
# TLS certificate path for SMTP STARTTLS
TLS_CERT_PATH=./certs/tls.crt
# TLS private key path for SMTP STARTTLS
TLS_KEY_PATH=./certs/tls.key
# Port for IMAP over TLS
IMAP_PORT=993

# ─── DKIM Signing ────────────────────────────────────────────────────────────
# Path to the DKIM private key file (RSA 2048). Default: ./dkim/private.key
DKIM_PRIVATE_KEY_PATH=./dkim/private.key
# DNS selector used in DKIM TXT record. Default: mail
DKIM_SELECTOR=mail

# ─── SRP Authentication ──────────────────────────────────────────────────────
# Bit length of the SRP prime (N). 2048 is the minimum recommended value.
SRP_PRIME_BITS=2048

# ─── API Service ─────────────────────────────────────────────────────────────
API_PORT=3001
API_BASE_URL=http://localhost:3001
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:4321

# ─── Web / Astro Frontend ────────────────────────────────────────────────────
WEB_PORT=4321
WEB_BASE_URL=http://localhost:4321

# ─── Session ─────────────────────────────────────────────────────────────────
# How long a session token remains valid (seconds). Default: 24 hours.
SESSION_TTL_SECONDS=86400

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Sliding window duration in milliseconds
RATE_LIMIT_WINDOW_MS=60000
# Maximum requests allowed per window per IP
RATE_LIMIT_MAX_REQUESTS=100

# ─── Argon2id Key Derivation ─────────────────────────────────────────────────
# Memory cost in MiB (OWASP minimum: 19 MiB; recommended: 64 MiB)
ARGON2_MEMORY_MB=65536
# Number of iterations (time cost)
ARGON2_ITERATIONS=3
# Degree of parallelism (threads)
ARGON2_PARALLELISM=4

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development

# =============================================================================
# Production Docker Compose (docker-compose.yml)
# The variables below are used by the production Compose stack.
# Variables marked (required) will cause docker compose to fail if unset.
# =============================================================================

# ─── Domain (required) ───────────────────────────────────────────────────────
# Public domain for HTTPS (Caddy) — e.g. mail.example.com
DOMAIN=mail.example.com
# SMTP_DOMAIN is already defined above — set it to your mail domain

# ─── Production Database ─────────────────────────────────────────────────────
# POSTGRES_DB, POSTGRES_USER are defined above (defaults: enclave)
# POSTGRES_PASSWORD is required in production — no default provided
# POSTGRES_PASSWORD=<generate-strong-password>
# DATABASE_URL is constructed automatically in docker-compose.yml

# ─── Production Redis ────────────────────────────────────────────────────────
# Required in production — Redis is password-protected
# REDIS_PASSWORD=<generate-strong-password>
# REDIS_URL is constructed automatically in docker-compose.yml

# ─── Production TLS Certificates ─────────────────────────────────────────────
# Paths inside the server container (mounted via 'certs' volume)
# TLS_CERT_PATH=/certs/server.crt
# TLS_KEY_PATH=/certs/server.key
# DKIM_PRIVATE_KEY_PATH=/certs/dkim.key

# ─── Production API ──────────────────────────────────────────────────────────
# CORS_ORIGINS is set automatically in docker-compose.yml to https://${DOMAIN}
# PUBLIC_API_URL is set automatically in docker-compose.yml to https://${DOMAIN}/api
