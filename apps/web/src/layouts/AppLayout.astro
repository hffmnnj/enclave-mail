---
import '../styles/globals.css';
import { MobileShell } from '../components/MobileShell';
import { SecurityStatusBar } from '../components/SecurityStatusBar';

interface Props {
  title?: string;
}

const { title = 'Enclave Mail' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0F1117" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <title>{title} &mdash; Enclave Mail</title>
  </head>
  <body class="no-horizontal-scroll bg-background text-text-primary min-h-screen">
    <MobileShell client:load currentPath={currentPath}>
      <slot />
    </MobileShell>
    <SecurityStatusBar client:load />

    <script>
      import { registerServiceWorker } from '../lib/sw-register';
      registerServiceWorker();
    </script>
  </body>
</html>
