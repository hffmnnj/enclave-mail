---
// Offline fallback page — served by the service worker when navigation
// requests fail and no cached version is available. Intentionally minimal:
// no JS islands, no external dependencies, fully self-contained.
const nonce = Astro.locals.nonce;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Offline — Enclave Mail</title>
    <meta name="theme-color" content="#0F1117" />
    <style nonce={nonce}>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        background: #0f1117;
        color: #e2e4ea;
        font-family:
          Inter,
          system-ui,
          -apple-system,
          sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        padding: 2rem;
        text-align: center;
      }
      .icon {
        font-size: 3rem;
        color: #4a9bae;
        line-height: 1;
      }
      h1 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #e2e4ea;
      }
      p {
        color: #8b8fa3;
        font-size: 0.875rem;
        max-width: 360px;
        line-height: 1.6;
      }
      .retry-btn {
        margin-top: 0.5rem;
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.5rem 1rem;
        font-size: 0.8125rem;
        font-weight: 500;
        color: #e2e4ea;
        background: transparent;
        border: 1px solid #2a2d3a;
        border-radius: 0.375rem;
        cursor: pointer;
        transition:
          background 0.15s,
          border-color 0.15s;
      }
      .retry-btn:hover {
        background: #1a1d28;
        border-color: #3a3d4a;
      }
      .retry-btn:focus-visible {
        outline: 2px solid #4a9bae;
        outline-offset: 2px;
      }
    </style>
  </head>
  <body>
    <div class="icon" aria-hidden="true">✉</div>
    <h1>You're offline</h1>
    <p>
      Enclave Mail couldn't connect to the server. Previously loaded messages
      are available in your inbox. New messages will sync when you reconnect.
    </p>
    <button id="retry-btn" class="retry-btn">
      Try again
    </button>
    <script nonce={nonce}>
      const retryButton = document.getElementById('retry-btn');
      retryButton?.addEventListener('click', () => {
        window.location.reload();
      });
    </script>
  </body>
</html>
